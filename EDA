sp.info()
# we have the names of our features below.
# all features are numeric except extracurricular activities.
# Extracurricular Activities will need to be converted to 0,1 numeric values, boolean typing.

# I ran into issues here, where all values in Extracurricular Activities were showing as 0.
# I reloaded the dataset to start from scratch and ensure the error was fixed with a mapping function.
sp = pd.read_csv('Student_Performance_with_Attendance.csv')

sp['Extracurricular Activities'] = sp['Extracurricular Activities'].str.strip().str.title().map({"Yes": 1, "No": 0})

# Head and tail are shown to confirm Boolean mapping of Extracurricular Activites, where Yes=1 and No=0.
display(sp.head())

sp.tail()

sp['Risk'] = np.where(sp["Performance Index"] < 70, "At-Risk", "Not At Risk")
# We are adding a new features that shows "At-Risk" or "Not At-Risk" based on Performance Index > or < 70.

sp.head()

import sklearn as sk
# Now we can continue with train/test split to ensure data leakage is avoided, and our model is prepared for new data.

from sklearn.model_selection import train_test_split
from sklearn.linear_model import LogisticRegression
from sklearn.svm import SVC

X = sp.drop(['Performance Index','Sleep Hours','Risk','Sample Question Papers Practiced'],axis=1)
Y = (sp['Performance Index'] < 70).astype(int)
# We are dropping the target variable, Performance Index, from X.
# We are also dropping extra variables like Sleep Hours and Sample Question Papers Practiced
# Hours Studied, Previous Scores, Extracurricular Activities, and Attendance Rate are our focus input variables.
# We hypothesize that dropping these extra variables will not significantly impact the quality of our model.

X_train, X_test, Y_train, Y_test = train_test_split(X, Y, test_size=0.2,random_state=42)

X_train.head()

X_train.describe()

X_train.info()
# Now all features in the training set are numeric. Yay!

Y_train.value_counts()
# As hypothesized, there are more At-Risk flagging students than not in this dataset. I may adjust the parameters to be less strict in the future.
# For example, changing 70 to 65.

train_riskratio = 2124/5876
print(train_riskratio)
# the ratio of not at risk: at risk is about 36.15%

lr = LogisticRegression()
# We've uploaded the logistic regression model to use.

lr.fit(X_train,Y_train)
# fit the model to training data, not testing data.

Y_pred=lr.predict(X_test)
# predict results based on X_test data, and learned patterns from training data.

from sklearn.metrics import confusion_matrix,ConfusionMatrixDisplay,classification_report
# generate a confusion matrix support to understand how our model performed.

cm = confusion_matrix(Y_test,Y_pred,labels=lr.classes_)
# add source data and labels for readability.

ConfusionMatrixDisplay(cm,display_labels=lr.classes_).plot()
# our confusion matrix returned good results, with low underprediction and overprediction
# I'll need to ensure that the data isn't overfitting.
# The results are consistent with the training data's ratio of At-Risk (1) to Not At-Risk (0).

test_riskratio = 503/1439
print(test_riskratio)
print(train_riskratio)
# the not at-risk: at-risk ratio is about 34.95%, very close to the training risk ratio.

print(classification_report(Y_test,Y_pred,labels=lr.classes_))
# Accuracy is > 80%, which is a good sign that our model is working well.

# now we need to export the model.

import joblib
joblib.dump(lr, 'my_model.joblib')
